# Copy this to .env.local and fill values
# Run server with `npm run server` (server listens on PORT or 3001)
PORT=3001

# SMTP settings for Nodemailer
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=supersecret
SMTP_FROM=no-reply@example.com
CONTACT_TO_EMAIL=hello@alazarpro.com

# Set the client to call the server when running locally
VITE_CONTACT_API_URL=http://localhost:3001

# AI / Gemini: server endpoint + API Key
# Keep your real Gemini API key ONLY on the server (NOT in client bundles)
API_KEY=your_gemini_api_key_here
VITE_AI_API_URL=http://localhost:3001